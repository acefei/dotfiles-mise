#!/usr/bin/env bash
source "$MISE_PROJECT_ROOT/lib/utils.sh"

setup_vscode() {
    if ! command -v code &>/dev/null; then
        echo "VSCode not installed, skipping"
        return 0
    fi

    local vscode_dir
    if is_mac; then
        vscode_dir="$HOME/Library/Application Support/Code/User"
    else
        vscode_dir="$HOME/.config/Code/User"
    fi

    install -d "$vscode_dir"
    install -m 644 "$MISE_PROJECT_ROOT/agents/vscode/settings.json" "$vscode_dir/settings.json"
    install -m 644 "$MISE_PROJECT_ROOT/agents/vscode/keybindings.json" "$vscode_dir/keybindings.json"

    while IFS= read -r ext; do
        [[ "$ext" =~ ^#|^$ ]] && continue
        code --install-extension "$ext" --force
    done < "$MISE_PROJECT_ROOT/agents/vscode/extensions.txt"
}

# Claude Code plugin marketplaces to register.
#   format: "<marketplace-source>"  (GitHub owner/repo, git URL, or local path)
CLAUDE_MARKETPLACES=(
    "affaan-m/ECC"   # ECC = "everything claude code" (https://github.com/affaan-m/ECC)
    "acefei/agent-accelerator"   # https://github.com/acefei/agent-accelerator
)

# Claude Code plugins to install.
#   format: "<plugin>@<marketplace-name>"
CLAUDE_PLUGINS=(
    "ecc@ecc"
    "accelerator-core@agent-accelerator"
)

# Agent skill packs to install via the GitHub CLI (`gh skill` — preview).
# These are plain SKILL.md files — no build step, unlike installing the full repo.
# `gh` is already a managed mise tool with auth wired in install.sh (no node/npx).
# `gh skill` resolves to the latest tag, then default-branch HEAD.
#   format: "<source>"  (GitHub owner/repo or git URL)
CLAUDE_SKILLS=(
    "mattpocock/skills"   # https://github.com/mattpocock/skills
    "cli/cli"             # https://github.com/cli/cli/tree/trunk/skills (gh, gh-skill)
)

setup_claude() {
    if ! command -v claude &>/dev/null; then
        echo "Claude Code CLI not available (managed by mise), skipping Claude setup"
        return 0
    fi

    local claude_dir="$HOME/.claude"
    install -d "$claude_dir"

    # Don't clobber an existing settings.json (may contain user customizations).
    if [[ -e "$claude_dir/settings.json" ]]; then
        echo "Claude settings already exist, keeping current $claude_dir/settings.json"
    else
        install -m 644 "$MISE_PROJECT_ROOT/agents/claude/settings.json" "$claude_dir/settings.json"
    fi

    local marketplace plugin marketplace_name

    for marketplace in "${CLAUDE_MARKETPLACES[@]}"; do
        echo "Registering Claude plugin marketplace: $marketplace"
        # Adding an already-registered marketplace errors; fall back to update.
        # The marketplace name is its own (lowercased) identifier, derived here
        # from the last path segment of the source as a best-effort default.
        marketplace_name="${marketplace##*/}"
        claude plugin marketplace add "$marketplace" \
            || claude plugin marketplace update "${marketplace_name,,}" \
            || true
    done

    for plugin in "${CLAUDE_PLUGINS[@]}"; do
        echo "Installing Claude plugin: $plugin"
        claude plugin install "$plugin" \
            || echo "Plugin install failed for $plugin, continuing"
    done

    if [[ ${#CLAUDE_SKILLS[@]} -gt 0 ]] && command -v gh &>/dev/null; then
        local skill_source
        for skill_source in "${CLAUDE_SKILLS[@]}"; do
            echo "Installing Claude skill pack: $skill_source"
            # Install all skills into Claude Code, user-global, non-interactively.
            # `--all` requires a recent gh; install.sh keeps gh on the latest release.
            gh skill install "$skill_source" --all --agent claude-code --scope user --force \
                || echo "Skill install failed for $skill_source, continuing"
        done
    fi
}

setup_vscode
setup_claude